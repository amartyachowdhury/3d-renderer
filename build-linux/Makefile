	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_rasterizer.dir/build.make CMakeFiles/test_rasterizer.dir/tests/test_rasterizer.cpp.s
.PHONY : tests/test_rasterizer.cpp.s

tests/test_raycaster.o: tests/test_raycaster.cpp.o
.PHONY : tests/test_raycaster.o

# target to build an object file
tests/test_raycaster.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_raycaster.dir/build.make CMakeFiles/test_raycaster.dir/tests/test_raycaster.cpp.o
.PHONY : tests/test_raycaster.cpp.o

tests/test_raycaster.i: tests/test_raycaster.cpp.i
.PHONY : tests/test_raycaster.i

# target to preprocess a source file
tests/test_raycaster.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_raycaster.dir/build.make CMakeFiles/test_raycaster.dir/tests/test_raycaster.cpp.i
.PHONY : tests/test_raycaster.cpp.i

tests/test_raycaster.s: tests/test_raycaster.cpp.s
.PHONY : tests/test_raycaster.s

# target to generate assembly for a file
tests/test_raycaster.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_raycaster.dir/build.make CMakeFiles/test_raycaster.dir/tests/test_raycaster.cpp.s
.PHONY : tests/test_raycaster.cpp.s

