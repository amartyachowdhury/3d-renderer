# Cornell box scene with quads and spheres.
resolution 640 360
samples 20
max_depth 50
camera 0 1.5 6  0 1 0  0 1 0  35 0.02 6

# Floor
quad -1 0 -1  1 0 -1  1 0 1  -1 0 1  lambertian 0.5 0.5 0.5

# Ceiling
quad -1 5 -1  1 5 -1  1 5 1  -1 5 1  emissive 4 4 4

# Back wall
quad -1 0 -1  1 0 -1  1 5 -1  -1 5 -1  lambertian 0.2 0.35 0.7

# Left wall (red)
quad -1 0 -1  -1 0 1  -1 5 1  -1 5 -1  lambertian 0.8 0.2 0.2

# Right wall (green)
quad 1 0 1  1 0 -1  1 5 -1  1 5 1  lambertian 0.2 0.8 0.2

# Center glass sphere
sphere 0 1 0 1 dielectric 1.5

# Textured sphere
sphere -1.5 0.8 -0.5 0.8 textured assets/textures/checker.png

# Right metal sphere
sphere 2.2 1 0 1 metal 0.85 0.75 0.45 0.05
