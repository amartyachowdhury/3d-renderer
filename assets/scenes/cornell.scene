# Cornell-style scene for the ray tracer scene loader.
resolution 640 360
samples 20
max_depth 50
camera 0 1.5 6  0 1 0  0 1 0  35 0.02 6

# Ground
sphere 0 -1000 0 1000 lambertian 0.5 0.5 0.5

# Ceiling light
sphere 0 4.8 0 0.6 emissive 4 4 4

# Center glass sphere
sphere 0 1 0 1 dielectric 1.5

# Textured sphere
sphere -1.5 0.8 -0.5 0.8 textured assets/textures/checker.png

# Right metal sphere
sphere 2.2 1 0 1 metal 0.85 0.75 0.45 0.05

# Back wall tint
sphere 0 1 -3 1.2 lambertian 0.2 0.35 0.7
